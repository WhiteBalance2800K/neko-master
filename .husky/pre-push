#!/usr/bin/env sh

# Only run checks when pushing to main branch
while read local_ref local_oid remote_ref remote_oid; do
  if echo "$remote_ref" | grep -q "refs/heads/main$"; then
    echo "🔍 Pushing to main — running pre-push checks..."

    echo "→ Running collector type check..."
    corepack pnpm --filter @neko-master/collector exec tsc --noEmit || exit 1

    echo "→ Building web app..."
    corepack pnpm --filter @neko-master/web build || exit 1

    echo "✅ All checks passed."
    exit 0
  fi
done

# Not pushing to main, allow push
exit 0
